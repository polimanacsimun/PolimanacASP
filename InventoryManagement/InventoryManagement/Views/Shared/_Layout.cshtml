@using InventoryManagement.Domain.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Inventory Management</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InventoryManagement.styles.css" asp-append-version="true" />
</head>

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var isDashboard = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);

    string? dashboardDisplayName = null;

    if (isDashboard && User.Identity?.IsAuthenticated == true)
    {
        var appUser = await UserManager.GetUserAsync(User);
        dashboardDisplayName = appUser == null
            ? User.Identity?.Name
            : $"{appUser.FirstName} {appUser.LastName}";
    }

    var pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";

    if (isDashboard && !string.IsNullOrWhiteSpace(dashboardDisplayName))
    {
        pageTitle = $"Dashboard - Hello, {dashboardDisplayName}";
    }

    Func<string, string> active = controller =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            ? "active"
            : string.Empty;
}

<body class="app-body d-flex flex-column min-vh-100">
    <header class="site-header py-2">
        <div class="container-fluid px-3 px-xl-4">
            <nav class="navbar navbar-expand-lg p-0 align-items-center" aria-label="Main navigation">
                <a class="navbar-brand app-brand d-flex align-items-center me-4" asp-controller="Home" asp-action="Index">
                    <div class="brand-mark me-2" aria-hidden="true">
                        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="3" y="4" width="18" height="4" rx="1.2" fill="white" fill-opacity=".95" />
                            <rect x="3" y="10" width="18" height="4" rx="1.2" fill="white" fill-opacity=".82" />
                            <rect x="3" y="16" width="11" height="4" rx="1.2" fill="white" fill-opacity=".68" />
                        </svg>
                    </div>
                    <div class="d-flex flex-column lh-sm">
                        <span class="brand-title">Inventory Management</span>
                        <small class="brand-subtitle">Operations & Inventory Dashboard</small>
                    </div>
                </a>

                <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav align-items-lg-center me-auto mb-2 mb-lg-0 app-nav-list">
                        <li class="nav-item">
                            <a class="nav-link @active("Product")" asp-controller="Product" asp-action="Index">Products</a>
                        </li>

                        <li class="nav-item nav-divider d-none d-lg-flex" aria-hidden="true"></li>

                        <li class="nav-item">
                            <a class="nav-link @active("Supplier")" asp-controller="Supplier" asp-action="Index">Suppliers</a>
                        </li>

                        <li class="nav-item nav-divider d-none d-lg-flex" aria-hidden="true"></li>

                        <li class="nav-item">
                            <a class="nav-link @active("Category")" asp-controller="Category" asp-action="Index">Categories</a>
                        </li>

                        <li class="nav-item nav-divider d-none d-lg-flex" aria-hidden="true"></li>

                        <li class="nav-item">
                            <a class="nav-link @active("Warehouse")" asp-controller="Warehouse" asp-action="Index">Warehouses</a>
                        </li>

                        <li class="nav-item nav-group-divider d-none d-lg-flex" aria-hidden="true"></li>

                        <li class="nav-item">
                            <a class="nav-link @active("User")" asp-controller="User" asp-action="Index">Users</a>
                        </li>

                        <li class="nav-item nav-divider d-none d-lg-flex" aria-hidden="true"></li>

                        <li class="nav-item">
                            <a class="nav-link @active("Order")" asp-controller="Order" asp-action="Index">Orders</a>
                        </li>

                        <li class="nav-item nav-divider d-none d-lg-flex" aria-hidden="true"></li>

                        <li class="nav-item">
                            <a class="nav-link @active("InventoryItem")" href="/inventory">Inventory</a>
                        </li>

                        <li class="nav-item nav-divider d-none d-lg-flex" aria-hidden="true"></li>

                        <li class="nav-item">
                            <a class="nav-link @active("OrderItem")" href="/order-items">Order Items</a>
                        </li>
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </nav>
        </div>
    </header>

    <main role="main" class="flex-grow-1 py-4 app-main">
        <div class="container app-page-container">
            <div class="app-page-heading d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
                <h2 class="h5 mb-0">@pageTitle</h2>
                <div class="text-muted small">
                    <span class="me-2">Status: <strong class="text-success">Operational</strong></span>
                    <span class="d-none d-md-inline">| Last updated: @DateTime.Now.ToString("yyyy-MM-dd")</span>
                </div>
            </div>

            <section class="app-content-card p-3 p-md-4 rounded-4 shadow-sm">
                @RenderBody()
            </section>
        </div>
    </main>

    <footer class="site-footer mt-auto py-3">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center small text-muted">
            <div>&copy; @DateTime.Now.Year Inventory Management</div>
            <div class="mt-2 mt-md-0">Designed for enterprise inventory & operations — Confidential</div>
        </div>
    </footer>

    @if (TempData["ToastMessage"] != null)
    {
        <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1080">
            <div id="appToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        @TempData["ToastMessage"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/autocomplete-dropdown.js" asp-append-version="true"></script>
    <script src="~/js/custom-date-input.js" asp-append-version="true"></script>
    <script src="~/js/ui-polish.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
