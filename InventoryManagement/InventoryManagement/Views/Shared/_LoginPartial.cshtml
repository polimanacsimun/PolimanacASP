@using InventoryManagement.Domain.Models
@using Microsoft.AspNetCore.Identity

@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<ul class="navbar-nav ms-auto user-nav align-items-lg-center">
    @if (SignInManager.IsSignedIn(User))
    {
        var appUser = await UserManager.GetUserAsync(User);
        var displayName = appUser == null
            ? User.Identity?.Name
            : $"{appUser.FirstName} {appUser.LastName}";

        <li class="nav-item">
            <span class="user-greeting">
                <span class="user-greeting-dot" aria-hidden="true"></span>
                <span>@displayName</span>
            </span>
        </li>
        <li class="user-action-divider d-none d-lg-block" aria-hidden="true"></li>
        <li class="nav-item">
            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                <button type="submit" class="logout-button">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="auth-nav-link" asp-controller="Account" asp-action="Register">Register</a>
        </li>
        <li class="user-action-divider d-none d-lg-block" aria-hidden="true"></li>
        <li class="nav-item">
            <a class="auth-nav-link" asp-controller="Account" asp-action="Login">Login</a>
        </li>
    }
</ul>
