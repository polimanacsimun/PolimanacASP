@model IEnumerable<InventoryManagement.Domain.Models.Supplier>
@using System.Linq

@{
    ViewData["Title"] = "Suppliers";
}

<div class="container my-4">
  <!-- Breadcrumbs -->
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb bg-transparent p-0">
      <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
      <li class="breadcrumb-item active" aria-current="page">Suppliers</li>
    </ol>
  </nav>

  <!-- Page header -->
  <div class="d-flex align-items-start justify-content-between mb-4">
    <div>
      <h1 class="h3 mb-1">Supplier Directory</h1>
      <p class="text-muted mb-0">Overview of all suppliers, contact details, status and the products they provide. Read-only view for procurement and vendor management.</p>
    </div>
    <div class="text-end">
      <a href="/vendors/create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle"></i> Create Supplier
      </a>
    </div>
  </div>

  <!-- Summary cards -->
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card shadow-sm">
        <div class="card-body">
          <h6 class="text-muted mb-2">Total Suppliers</h6>
          <div class="d-flex align-items-center justify-content-between">
            <div class="display-6">@((Model?.Count() ?? 0))</div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm">
        <div class="card-body">
          <h6 class="text-muted mb-2">Total Products</h6>
          <div class="d-flex align-items-center justify-content-between">
            <div class="display-6">@((Model?.Sum(s => s.Products?.Count() ?? 0)) ?? 0)</div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-body">
          <h6 class="text-muted mb-2">Guidance</h6>
          <p class="mb-0 text-muted">Click "Details" to view the supplier profile. Expand the product lists to inspect relationships between suppliers and inventory items.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Supplier list with search -->
  <div class="row">
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom">
          <div class="row g-2 align-items-center">
            <div class="col-md-8">
              <div class="input-group input-group-sm">
                <span class="input-group-text bg-light border-0">
                  <i class="bi bi-search"></i>
                </span>
                <input type="text" id="supplierSearchInput" class="form-control border-start-0" placeholder="Search by name, email, phone, address or contact person..." />
              </div>
            </div>
            <div class="col-md-4 text-end">
              <button type="button" id="clearSupplierSearch" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-x-circle"></i> Clear
              </button>
              <span id="supplierSearchLoading" class="ms-2" style="display: none;">
                <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
                <small class="text-muted ms-1">Searching...</small>
              </span>
            </div>
          </div>
        </div>

        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-4">Supplier</th>
                  <th>Address</th>
                  <th>Phone</th>
                  <th>Contact Person</th>
                  <th>Status</th>
                  <th class="text-end pe-4">Actions</th>
                </tr>
              </thead>
              <tbody id="supplierTableBody">
                @await Html.PartialAsync("_SupplierTableRows", Model)
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            let searchTimeout;

            // Handle supplier search input
            $('#supplierSearchInput').on('input', function() {
                clearTimeout(searchTimeout);
                const term = $(this).val().trim();

                // Show loading indicator
                $('#supplierSearchLoading').show();

                // Debounce search requests (300ms)
                searchTimeout = setTimeout(function() {
                    $.ajax({
                        url: '/vendors/search',
                        data: { term: term },
                        method: 'GET',
                        timeout: 5000,
                        success: function(html) {
                            // Fade out and replace content
                            $('#supplierTableBody').fadeOut(150, function() {
                                $(this).html(html).fadeIn(150);
                            });
                        },
                        error: function() {
                            $('#supplierTableBody').html('<tr><td colspan="6" class="text-center text-danger py-4">Error loading results. Please try again.</td></tr>');
                        },
                        complete: function() {
                            // Hide loading indicator
                            $('#supplierSearchLoading').hide();
                        }
                    });
                }, 300);
            });

            // Handle clear button
            $('#clearSupplierSearch').on('click', function() {
                $('#supplierSearchInput').val('').focus();
                clearTimeout(searchTimeout);
                $('#supplierSearchLoading').show();

                // Reload all suppliers
                $.ajax({
                    url: '/vendors/search',
                    data: { term: '' },
                    method: 'GET',
                    timeout: 5000,
                    success: function(html) {
                        $('#supplierTableBody').fadeOut(150, function() {
                            $(this).html(html).fadeIn(150);
                        });
                    },
                    complete: function() {
                        $('#supplierSearchLoading').hide();
                    }
                });
            });
        });
    </script>
}

