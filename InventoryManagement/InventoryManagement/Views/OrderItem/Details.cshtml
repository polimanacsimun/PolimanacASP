@using System
@using System.Globalization
@model InventoryManagement.Domain.Models.OrderItem

@{
    ViewData["Title"] = "Order Item Details";
    var culture = CultureInfo.CurrentCulture;
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a href="/order-items">Order Items</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    <!-- Header with Navigation Buttons -->
    <div class="d-flex align-items-start justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">@Model?.Product?.Name</h1>
            <p class="text-muted mb-0">Order item in @Model?.Order?.OrderNumber</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/order-items/@Model?.Id/edit" class="btn btn-outline-info btn-sm" asp-authorize-role="Admin">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a href="/order-items/@Model?.Id/delete" class="btn btn-outline-danger btn-sm" asp-authorize-role="Admin">
                <i class="bi bi-trash"></i> Delete
            </a>
            <a href="/order-items" class="btn btn-outline-secondary btn-sm">
                &larr; Back
            </a>
        </div>
    </div>

    <div class="row g-3">
        <!-- Left Column: Order Item Information -->
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-light border-bottom">
                    <strong>Order Item Details</strong>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Order</dt>
                        <dd class="col-sm-8 fw-semibold">@Model?.Order?.OrderNumber</dd>

                        <dt class="col-sm-4 text-muted">Product</dt>
                        <dd class="col-sm-8 fw-semibold">@Model?.Product?.Name</dd>

                        <dt class="col-sm-4 text-muted">Quantity</dt>
                        <dd class="col-sm-8">@Model?.Quantity units</dd>

                        <dt class="col-sm-4 text-muted">Unit Price</dt>
                        <dd class="col-sm-8">@Model?.UnitPrice.ToString("C", culture)</dd>

                        <dt class="col-sm-4 text-muted">Discount</dt>
                        <dd class="col-sm-8">@Model?.Discount.ToString("C", culture)</dd>

                        <dt class="col-sm-4 text-muted">Total Price</dt>
                        <dd class="col-sm-8 fw-semibold">@Model?.TotalPrice.ToString("C", culture)</dd>

                        <dt class="col-sm-4 text-muted">Created At</dt>
                        <dd class="col-sm-8">@Model?.CreatedAt.ToString("dd MMM yyyy HH:mm", culture)</dd>
                    </dl>
                </div>
                <div class="card-footer bg-light text-muted small">
                    Item ID: <span class="text-body">@Model?.Id</span> | Updated: @DateTime.Now.ToString("dd MMM yyyy HH:mm", culture)
                </div>
            </div>
        </div>

        <!-- Right Column: Price Summary -->
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light border-bottom">
                    <strong>Price Summary</strong>
                </div>
                <div class="card-body">
                    <div class="row g-3 text-center">
                        <div class="col-12">
                            <div class="p-3 border rounded">
                                <div class="h6 mb-1">Unit Price</div>
                                <div class="fs-4 fw-bold">@Model?.UnitPrice.ToString("C", culture)</div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="p-3 border rounded">
                                <div class="h6 mb-1">Quantity × Unit Price</div>
                                <div class="fs-5 fw-semibold">@Model?.Quantity × @Model?.UnitPrice.ToString("C", culture)</div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="p-3 border rounded bg-light">
                                <div class="h6 mb-1">Discount</div>
                                <div class="fs-5 text-danger">-@Model?.Discount.ToString("C", culture)</div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="p-3 border rounded bg-success bg-opacity-10">
                                <div class="h6 mb-1">Total</div>
                                <div class="fs-3 fw-bold text-success">@Model?.TotalPrice.ToString("C", culture)</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light text-muted small">
                    <div>Created: @Model?.CreatedAt.ToString("d", culture)</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer Navigation -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-muted small">
            Created: @Model?.CreatedAt.ToString("f", culture)
        </div>
        <div class="d-flex gap-2">
            <a href="/order-items/@Model?.Id/edit" class="btn btn-sm btn-outline-info" asp-authorize-role="Admin">
                <i class="bi bi-pencil"></i> Edit Item
            </a>
            <a href="/order-items" class="btn btn-sm btn-outline-secondary">
                Back to Order Items
            </a>
        </div>
    </div>
</div>
