@using InventoryManagement.ViewModels.OrderItem
@using InventoryManagement.ViewModels.Shared
@model OrderItemFormModel

@{
    ViewData["Title"] = "Edit Order Item";
}

<div class="container my-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a href="/order-items">Order Items</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit Item</li>
        </ol>
    </nav>

    <!-- Page header -->
    <div class="mb-4">
        <h1 class="h3 mb-1">Edit Order Item</h1>
        <p class="text-muted mb-0">Modify order item information and pricing.</p>
    </div>

    <div class="row">
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-light border-bottom">
                    <strong>Order Item Details</strong>
                </div>

                <div class="card-body">
                    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
                        <!-- Validation Summary -->
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger alert-dismissible fade show" role="alert">
                                <strong>Please correct the following errors:</strong>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        <!-- Hidden ID -->
                        <input asp-for="Id" type="hidden" />

                        <!-- Order Autocomplete -->
                        @{
                            var orderAutocomplete = new AutocompleteDropdownModel
                            {
                                Label = "Order",
                                HiddenInputName = "OrderId",
                                HiddenInputId = "OrderId",
                                DisplayInputId = "OrderDisplay",
                                SearchUrl = "/lookup/orders",
                                SelectedId = Model.OrderId,
                                DisplayValue = Model.OrderDisplayName,
                                Placeholder = "Search order...",
                                HelpText = "Start typing to search orders."
                            };
                        }
                        @await Html.PartialAsync("_AutocompleteDropdown", orderAutocomplete)

                        <!-- Product Autocomplete -->
                        @{
                            var productAutocomplete = new AutocompleteDropdownModel
                            {
                                Label = "Product",
                                HiddenInputName = "ProductId",
                                HiddenInputId = "ProductId",
                                DisplayInputId = "ProductDisplay",
                                SearchUrl = "/lookup/products",
                                SelectedId = Model.ProductId,
                                DisplayValue = Model.ProductDisplayName,
                                Placeholder = "Search product...",
                                HelpText = "Start typing to search products."
                            };
                        }
                        @await Html.PartialAsync("_AutocompleteDropdown", productAutocomplete)

                        <!-- Quantity -->
                        <div class="mb-3">
                            <label asp-for="Quantity" class="form-label">Quantity</label>
                            <input asp-for="Quantity" type="number" class="form-control" placeholder="0" />
                            <span asp-validation-for="Quantity" class="invalid-feedback d-block"></span>
                        </div>

                        <!-- Unit Price -->
                        <div class="mb-3">
                            <label asp-for="UnitPrice" class="form-label">Unit Price</label>
                            <input asp-for="UnitPrice" type="number" step="0.01" class="form-control" placeholder="0.00" />
                            <span asp-validation-for="UnitPrice" class="invalid-feedback d-block"></span>
                        </div>

                        <!-- Discount -->
                        <div class="mb-3">
                            <label asp-for="Discount" class="form-label">Discount (Optional)</label>
                            <input asp-for="Discount" type="number" step="0.01" class="form-control" placeholder="0.00" />
                            <span asp-validation-for="Discount" class="invalid-feedback d-block"></span>
                        </div>

                        <!-- Total Price -->
                        <div class="mb-3">
                            <label asp-for="TotalPrice" class="form-label">Total Price</label>
                            <input asp-for="TotalPrice" type="number" step="0.01" class="form-control" placeholder="0.00" />
                            <span asp-validation-for="TotalPrice" class="invalid-feedback d-block"></span>
                        </div>

                        <!-- Created At (Custom Date/Time Input) -->
                        @{
                            var dateTimeInput = new DateTimeInputModel
                            {
                                Label = "Created At",
                                InputName = "CreatedAt",
                                InputId = "CreatedAt",
                                Value = Model.CreatedAt,
                                IncludeTime = true,
                                IsRequired = true,
                                Placeholder = "Select date and time",
                                HelpText = "Date and time when this order item was created."
                            };
                        }
                        @await Html.PartialAsync("_DateTimeInput", dateTimeInput)

                        <!-- Anti-forgery token -->
                        @Html.AntiForgeryToken()

                        <!-- Form Actions -->
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Save Changes
                            </button>
                            <a href="/order-items/@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/autocomplete-dropdown.js"></script>
    <script src="~/js/custom-date-input.js"></script>
}
