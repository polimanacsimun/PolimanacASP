@using InventoryManagement.ViewModels.Category
@model CategoryFormModel

@{
    ViewData["Title"] = "Edit Category";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square"></i> Edit Category
                    </h4>
                </div>

                <div class="card-body p-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <form method="post" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()

                        <!-- Hidden ID -->
                        <input asp-for="Id" type="hidden" />

                        <!-- Category Name -->
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Category Name</label>
                            <input asp-for="Name" class="form-control" placeholder="Enter category name" />
                            <span asp-validation-for="Name" class="invalid-feedback d-block"></span>
                        </div>

                        <!-- Description -->
                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter category description"></textarea>
                            <span asp-validation-for="Description" class="invalid-feedback d-block"></span>
                        </div>

                        <!-- Form Actions -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-info btn-lg text-white">
                                <i class="bi bi-check-circle"></i> Save Changes
                            </button>
                            <a href="/categories/@Model.Id" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
