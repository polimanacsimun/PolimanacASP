@using System.Linq
@model IEnumerable<InventoryManagement.Domain.Models.Category>

@{
    ViewData["Title"] = "Categories";
    var categories = Model ?? Enumerable.Empty<InventoryManagement.Domain.Models.Category>();
    var totalCategories = categories.Count();
    var totalProducts = categories.Sum(c => c.Products?.Count ?? 0);
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Categories</li>
        </ol>
    </nav>

    <header class="mb-4">
        <div class="d-flex align-items-start justify-content-between">
            <div>
                <h1 class="h3 mb-1">Category Catalog</h1>
                <p class="text-muted mb-0">Overview of product groupings used across warehouses. Use the details links to inspect related products and category metadata.</p>
            </div>
            <div class="text-end">
                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex gap-3 align-items-center">
                            <div>
                                <div class="text-uppercase text-muted small">Categories</div>
                                <div class="h5 mb-0">@totalCategories</div>
                            </div>
                            <div class="border-start ps-3">
                                <div class="text-uppercase text-muted small">Total Products</div>
                                <div class="h5 mb-0">@totalProducts</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @if (categories.Any())
            {
                @foreach (var category in categories)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h5 class="card-title mb-1">@category.Name</h5>
                                        <p class="text-muted small mb-2">
                                            @if (!string.IsNullOrEmpty(category.Description))
                                            {
                                                @category.Description
                                            }
                                            else
                                            {
                                                <em>No description</em>
                                            }
                                        </p>
                                    </div>
                                    <div class="text-end ms-3">
                                        <span class="badge bg-primary fs-6">@((category.Products?.Count) ?? 0)</span>
                                    </div>
                                </div>

                                <div class="mt-auto pt-3 d-flex justify-content-between align-items-center">
                                    <div class="text-muted small">
                                        <strong class="me-1">ID:</strong> @category.Id
                                    </div>
                                    <div>
                                        <a asp-controller="Category" asp-action="Details" asp-route-id="@category.Id" class="btn btn-sm btn-outline-primary">
                                            Details
                                        </a>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-0 py-2">
                                <div class="small text-muted">Products: @((category.Products?.Count) ?? 0)</div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        @if (!categories.Any())
        {
            <div class="mt-5 text-center text-muted">
                <div class="p-4">
                    <h4 class="mb-2">No categories found</h4>
                    <p class="mb-0">There are currently no categories in the system. Inventory managers can add categories from the administrative console.</p>
                </div>
            </div>
        }
    </section>

    <footer class="mt-4 d-flex justify-content-between align-items-center">
        <div class="small text-muted">Last refreshed: @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm 'UTC'")</div>
        <div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">Back to dashboard</a>
        </div>
    </footer>
</div>
