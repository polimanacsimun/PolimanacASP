@using System.Linq
@model IEnumerable<InventoryManagement.Domain.Models.Category>

@{
    ViewData["Title"] = "Categories";
    var categories = Model ?? Enumerable.Empty<InventoryManagement.Domain.Models.Category>();
    var totalCategories = categories.Count();
    var totalProducts = categories.Sum(c => c.Products?.Count ?? 0);
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Categories</li>
        </ol>
    </nav>

    <header class="mb-4">
        <div class="d-flex align-items-start justify-content-between">
            <div>
                <h1 class="h3 mb-1">Category Catalog</h1>
                <p class="text-muted mb-0">Overview of product groupings used across warehouses. Use the details links to inspect related products and category metadata.</p>
            </div>
            <div class="text-end">
                <div class="mb-2">
                    <a href="/categories/create" class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-circle"></i> Create Category
                    </a>
                </div>
                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex gap-3 align-items-center">
                            <div>
                                <div class="text-uppercase text-muted small">Categories</div>
                                <div class="h5 mb-0">@totalCategories</div>
                            </div>
                            <div class="border-start ps-3">
                                <div class="text-uppercase text-muted small">Total Products</div>
                                <div class="h5 mb-0">@totalProducts</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Search Section -->
    <div class="card shadow-sm mb-4">
        <div class="card-body pb-0">
            <div class="row g-2 align-items-center">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" id="categorySearchInput" class="form-control border-start-0" placeholder="Search by category name or description..." />
                    </div>
                </div>
                <div class="col-md-4 text-end">
                    <button type="button" id="clearCategorySearch" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-x-circle"></i> Clear
                    </button>
                    <span id="categorySearchLoading" class="ms-2" style="display: none;">
                        <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
                        <small class="text-muted ms-1">Searching...</small>
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Categories Table -->
    <section>
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Name</th>
                            <th>Description</th>
                            <th class="text-end">Products</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="categoryTableBody">
                        @await Html.PartialAsync("_CategoryTableRows", categories)
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <footer class="mt-4 d-flex justify-content-between align-items-center">
        <div class="small text-muted">Last refreshed: @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm 'UTC'")</div>
        <div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">Back to dashboard</a>
        </div>
    </footer>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            let searchTimeout;

            // Handle category search input
            $('#categorySearchInput').on('input', function() {
                clearTimeout(searchTimeout);
                const term = $(this).val().trim();

                // Show loading indicator
                $('#categorySearchLoading').show();

                // Debounce search requests (300ms)
                searchTimeout = setTimeout(function() {
                    $.ajax({
                        url: '/categories/search',
                        data: { term: term },
                        method: 'GET',
                        timeout: 5000,
                        success: function(html) {
                            // Fade out and replace content
                            $('#categoryTableBody').fadeOut(150, function() {
                                $(this).html(html).fadeIn(150);
                            });
                        },
                        error: function() {
                            $('#categoryTableBody').html('<tr><td colspan="4" class="text-center text-danger py-4">Error loading results. Please try again.</td></tr>');
                        },
                        complete: function() {
                            // Hide loading indicator
                            $('#categorySearchLoading').hide();
                        }
                    });
                }, 300);
            });

            // Handle clear button
            $('#clearCategorySearch').on('click', function() {
                $('#categorySearchInput').val('').focus();
                clearTimeout(searchTimeout);
                $('#categorySearchLoading').show();

                // Reload all categories
                $.ajax({
                    url: '/categories/search',
                    data: { term: '' },
                    method: 'GET',
                    timeout: 5000,
                    success: function(html) {
                        $('#categoryTableBody').fadeOut(150, function() {
                            $(this).html(html).fadeIn(150);
                        });
                    },
                    complete: function() {
                        $('#categorySearchLoading').hide();
                    }
                });
            });
        });
    </script>
}
