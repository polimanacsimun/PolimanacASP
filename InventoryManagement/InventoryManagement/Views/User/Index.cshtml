@using System.Linq
@using InventoryManagement.Domain.Models
@using InventoryManagement.Domain.Enums
@model IEnumerable<User>

@{
    ViewData["Title"] = "Users";
    var users = Model?.ToList() ?? new List<User>();
    var totalUsers = users.Count;
    var administrators = users.Count(u => u.Role == UserRole.Administrator);
    var employees = users.Count(u => u.Role == UserRole.Employee);
    var customers = users.Count(u => u.Role == UserRole.Customer);
    var activeUsers = users.Count(u => u.IsActive);
    var inactiveUsers = totalUsers - activeUsers;

    Func<UserRole, string> RoleBadgeClass = r => r == UserRole.Administrator ? "bg-danger" : r == UserRole.Employee ? "bg-info text-dark" : "bg-success";
    Func<bool, string> StatusBadgeClass = a => a ? "bg-success" : "bg-secondary";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb bg-transparent p-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">Users</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h3 mb-1">Users</h1>
        <p class="text-muted mb-0">User and team management — view access, activity, and order history for system users.</p>
    </div>
    <div class="text-end d-flex gap-2">
        <a href="/users/create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-circle"></i> Create User
        </a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">Back to Dashboard</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">Total Users</h6>
                <div class="d-flex align-items-baseline">
                    <span class="display-6 fw-bold me-2">@totalUsers</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">Administrators</h6>
                <div class="d-flex align-items-baseline">
                    <span class="h4 fw-semibold text-danger me-2">@administrators</span>
                    <small class="text-muted">accounts</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">Employees</h6>
                <div class="d-flex align-items-baseline">
                    <span class="h4 fw-semibold text-info me-2">@employees</span>
                    <small class="text-muted">accounts</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">Customers</h6>
                <div class="d-flex align-items-baseline">
                    <span class="h4 fw-semibold text-success me-2">@customers</span>
                    <small class="text-muted">accounts</small>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12 col-md-6">
        <div class="card shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="card-subtitle text-muted">Active Users</h6>
                    <div class="h5 mb-0">@activeUsers</div>
                </div>
                <div class="text-end">
                    <span class="badge @StatusBadgeClass(true) me-2">Active</span>
                    <span class="badge @StatusBadgeClass(false)">Inactive: @inactiveUsers</span>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!users.Any())
{
    <div class="card border-0 shadow-sm p-4 text-center">
        <div class="mb-3">
            <h4 class="mb-1">No users found</h4>
            <p class="text-muted mb-0">There are currently no users in the system. Once users register or are added, they will appear here.</p>
        </div>
        <div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Return to Dashboard</a>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-header bg-white border-bottom">
            <div class="row g-2 align-items-center">
                <div class="col-md-8">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-0">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" id="userSearchInput" class="form-control border-start-0" placeholder="Search by first name, last name, email or role..." />
                    </div>
                </div>
                <div class="col-md-4 text-end">
                    <button type="button" id="clearUserSearch" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-x-circle"></i> Clear
                    </button>
                    <span id="userSearchLoading" class="ms-2" style="display: none;">
                        <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
                        <small class="text-muted ms-1">Searching...</small>
                    </span>
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small">
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Role</th>
                            <th scope="col">Registered</th>
                            <th scope="col">Orders</th>
                            <th scope="col">Status</th>
                            <th scope="col" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="userTableBody">
                        @await Html.PartialAsync("_UserTableRows", users)
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<footer class="mt-4 d-flex justify-content-between align-items-center small text-muted">
    <div>Last updated: @DateTime.Now.ToString("f")</div>
    <div>
        <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Back to Dashboard</a>
    </div>
</footer>

@section Scripts {
    <script>
        $(document).ready(function() {
            let searchTimeout;

            // Handle user search input
            $('#userSearchInput').on('input', function() {
                clearTimeout(searchTimeout);
                const term = $(this).val().trim();

                // Show loading indicator
                $('#userSearchLoading').show();

                // Debounce search requests (300ms)
                searchTimeout = setTimeout(function() {
                    $.ajax({
                        url: '/users/search',
                        data: { term: term },
                        method: 'GET',
                        timeout: 5000,
                        success: function(html) {
                            // Fade out and replace content
                            $('#userTableBody').fadeOut(150, function() {
                                $(this).html(html).fadeIn(150);
                            });
                        },
                        error: function() {
                            $('#userTableBody').html('<tr><td colspan="6" class="text-center text-danger py-4">Error loading results. Please try again.</td></tr>');
                        },
                        complete: function() {
                            // Hide loading indicator
                            $('#userSearchLoading').hide();
                        }
                    });
                }, 300);
            });

            // Handle clear button
            $('#clearUserSearch').on('click', function() {
                $('#userSearchInput').val('').focus();
                clearTimeout(searchTimeout);
                $('#userSearchLoading').show();

                // Reload all users
                $.ajax({
                    url: '/users/search',
                    data: { term: '' },
                    method: 'GET',
                    timeout: 5000,
                    success: function(html) {
                        $('#userTableBody').fadeOut(150, function() {
                            $(this).html(html).fadeIn(150);
                        });
                    },
                    complete: function() {
                        $('#userSearchLoading').hide();
                    }
                });
            });
        });
    </script>
}
