@using InventoryManagement.Domain.Enums
@using InventoryManagement.ViewModels.Shared
@model InventoryManagement.ViewModels.User.UserFormModel

@{
    ViewData["Title"] = "Create User";
}

<div class="container my-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a href="/users">Users</a></li>
            <li class="breadcrumb-item active" aria-current="page">Create User</li>
        </ol>
    </nav>

    <!-- Page header -->
    <div class="mb-4">
        <h1 class="h3 mb-1">Create New User</h1>
        <p class="text-muted mb-0">Add a new user account to your inventory management system.</p>
    </div>

    <div class="row">
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-light border-bottom">
                    <strong>User Details</strong>
                </div>

                <div class="card-body">
                    <form asp-action="Create" method="post" novalidate>
                        <!-- Validation Summary -->
                        <div asp-validation-summary="All" class="alert alert-danger alert-dismissible fade show" role="alert" style="display:none;">
                            <strong>Please correct the following errors:</strong>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger alert-dismissible fade show" role="alert">
                                <strong>Please correct the following errors:</strong>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        <!-- First Name -->
                        <div class="mb-3">
                            <label asp-for="FirstName" class="form-label">First Name</label>
                            <input asp-for="FirstName" class="form-control" placeholder="e.g., John" />
                            <span asp-validation-for="FirstName" class="invalid-feedback d-block"></span>
                        </div>

                        <!-- Last Name -->
                        <div class="mb-3">
                            <label asp-for="LastName" class="form-label">Last Name</label>
                            <input asp-for="LastName" class="form-control" placeholder="e.g., Smith" />
                            <span asp-validation-for="LastName" class="invalid-feedback d-block"></span>
                        </div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="e.g., john.smith@company.com" />
                            <span asp-validation-for="Email" class="invalid-feedback d-block"></span>
                        </div>

                        <!-- Role -->
                        <div class="mb-3">
                            <label asp-for="Role" class="form-label">Role</label>
                            <select asp-for="Role" asp-items="Html.GetEnumSelectList<UserRole>()" class="form-select"></select>
                            <span asp-validation-for="Role" class="invalid-feedback d-block"></span>
                        </div>

                        <!-- Registration Date -->
                        @await Html.PartialAsync("_DateTimeInput", new DateTimeInputModel
                        {
                            Label = "Registration Date",
                            InputName = "RegistrationDate",
                            InputId = "RegistrationDate",
                            Value = Model.RegistrationDate,
                            Placeholder = "Enter registration date",
                            HelpText = "Use your browser language format.",
                            IncludeTime = false,
                            IsRequired = true
                        })

                        <!-- IsActive -->
                        <div class="mb-4">
                            <div class="form-check">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label">Active User</label>
                                <span asp-validation-for="IsActive" class="invalid-feedback d-block"></span>
                            </div>
                        </div>

                        <!-- Anti-forgery token -->
                        @Html.AntiForgeryToken()

                        <!-- Form Actions -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Create User
                            </button>
                            <a href="/users" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
