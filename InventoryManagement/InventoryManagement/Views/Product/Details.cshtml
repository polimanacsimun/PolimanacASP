@using System
@model InventoryManagement.Domain.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index">Products</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    <div class="d-flex align-items-start justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">@Model.Name</h1>
            <p class="text-muted mb-0">Product details and inventory metadata</p>
        </div>
        <div class="text-end">
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">
                &larr; Back to Products List
            </a>
        </div>
    </div>

    <div class="row g-3">
        <!-- Main Content Column -->
        <div class="col-lg-8">
            <!-- Core Product Information -->
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Core Product Information</h5>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Name</dt>
                        <dd class="col-sm-8 fw-semibold">@Model.Name</dd>

                        <dt class="col-sm-4 text-muted">Description</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrWhiteSpace(Model.Description))
                            {
                                <text>@Model.Description</text>
                            }
                            else
                            {
                                <span class="text-muted">No description</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <!-- Category & Supplier -->
            <div class="card shadow-sm mt-3">
                <div class="card-body">
                    <h5 class="card-title mb-3">Category & Supplier</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="row mb-0">
                                <dt class="col-5 text-muted">Category</dt>
                                <dd class="col-7 fw-semibold">
                                    @if (Model.Category != null)
                                    {
                                        <text>@Model.Category.Name</text>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Unassigned</span>
                                    }
                                </dd>

                                <dt class="col-5 text-muted">Supplier</dt>
                                <dd class="col-7 fw-semibold">
                                    @if (Model.Supplier != null)
                                    {
                                        <text>@Model.Supplier.Name</text>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Unassigned</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                        <div class="col-md-6 border-start ps-3">
                            <small class="text-muted">Related Info</small>
                            @if (Model.Supplier != null)
                            {
                                <p class="mb-1"><span class="text-muted">Supplier Email:</span> <span class="fw-semibold">@Model.Supplier.Email</span></p>
                                <p class="mb-0"><span class="text-muted">Supplier Contact:</span> <span class="fw-semibold">@Model.Supplier.ContactPerson</span></p>
                            }
                            else
                            {
                                <p class="mb-0 text-muted">No supplier information available</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Column -->
        <div class="col-lg-4">
            <!-- Pricing & Stock -->
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted mb-3">Pricing & Stock</h6>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <small class="text-muted">Price</small>
                            <div class="fs-5 fw-semibold">@Model.Price.ToString("C")</div>
                        </div>
                        <div class="text-end">
                            <small class="text-muted">Unit</small>
                            <div class="fw-semibold">@Model.UnitOfMeasure</div>
                        </div>
                    </div>

                    <hr />

                    <div class="mb-3">
                        <small class="text-muted">Minimum Stock Threshold</small>
                        <div class="fs-6 fw-semibold">@Model.MinimumStock</div>
                    </div>

                    <div class="mt-2">
                        <small class="text-muted">Product Type</small>
                        <div class="mt-2">
                            <span class="badge bg-info text-dark">@Model.Type</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Status & Metadata -->
            <div class="card shadow-sm mt-3">
                <div class="card-body">
                    <h6 class="text-muted mb-3">Status & Metadata</h6>

                    <dl class="row mb-3">
                        <dt class="col-6 text-muted">Created</dt>
                        <dd class="col-6 text-end">@Model.CreatedAt.ToString("d MMM yyyy")</dd>

                        <dt class="col-6 text-muted">Status</dt>
                        <dd class="col-6 text-end">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </dd>
                    </dl>

                    <div class="mt-4 text-center">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                            Back to Products List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
