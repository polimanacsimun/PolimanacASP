@model IEnumerable<InventoryManagement.Domain.Models.ProductAttachment>

@{
    var attachments = Model.ToList();
    var showActions = ViewData["ShowAttachmentActions"] as bool? ?? User.IsInRole("Admin");
}

@if (!attachments.Any())
{
    <div class="alert alert-light border mb-0">
        No attachments uploaded for this product yet.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>File</th>
                    <th>Type</th>
                    <th>Size</th>
                    <th>Uploaded</th>
                    @if (showActions)
                    {
                        <th class="text-end">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var attachment in attachments)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                @if (IsImage(attachment.ContentType))
                                {
                                    <a href="@attachment.FilePath" target="_blank" rel="noopener" aria-label="Open @attachment.FileName">
                                        <img src="@attachment.FilePath"
                                             alt="@attachment.FileName"
                                             class="rounded border object-fit-cover"
                                             style="width: 72px; height: 72px;" />
                                    </a>
                                }
                                <a href="@attachment.FilePath" target="_blank" rel="noopener">
                                    @attachment.FileName
                                </a>
                            </div>
                        </td>
                        <td>@attachment.ContentType</td>
                        <td>@FormatFileSize(attachment.FileSize)</td>
                        <td>@attachment.CreatedAt.ToLocalTime().ToString("g")</td>
                        @if (showActions)
                        {
                            <td class="text-end">
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger js-delete-attachment"
                                        data-attachment-id="@attachment.Id">
                                    Delete
                                </button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@functions {
    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        if (bytes < 1024 * 1024)
        {
            return $"{bytes / 1024d:0.##} KB";
        }

        return $"{bytes / 1024d / 1024d:0.##} MB";
    }

    private static bool IsImage(string contentType)
    {
        return contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
    }
}
