@using InventoryManagement.ViewModels.Product
@using InventoryManagement.Domain.Enums
@using InventoryManagement.ViewModels.Shared
@model ProductFormModel

@{
    ViewData["Title"] = "Edit Product";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square"></i> Edit Product
                    </h4>
                </div>

                <div class="card-body p-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <form method="post" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()

                        <input asp-for="Id" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Product Name</label>
                            <input asp-for="Name" class="form-control" placeholder="Enter product name" />
                            <span asp-validation-for="Name" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter product description"></textarea>
                            <span asp-validation-for="Description" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Price" class="form-label fw-semibold">Price</label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="Price" class="invalid-feedback d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="UnitOfMeasure" class="form-label fw-semibold">Unit of Measure</label>
                                    <input asp-for="UnitOfMeasure" class="form-control" placeholder="e.g., unit, ream, license" />
                                    <span asp-validation-for="UnitOfMeasure" class="invalid-feedback d-block"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="MinimumStock" class="form-label fw-semibold">Minimum Stock</label>
                                    <input asp-for="MinimumStock" type="number" class="form-control" placeholder="0" />
                                    <span asp-validation-for="MinimumStock" class="invalid-feedback d-block"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Type" class="form-label fw-semibold">Product Type</label>
                                    <select asp-for="Type" asp-items="Html.GetEnumSelectList<ProductType>()" class="form-select">
                                        <option value="">-- Select Type --</option>
                                    </select>
                                    <span asp-validation-for="Type" class="invalid-feedback d-block"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                @await Html.PartialAsync("_AutocompleteDropdown", new AutocompleteDropdownModel
                                {
                                    Label = "Category",
                                    HiddenInputName = "CategoryId",
                                    HiddenInputId = "CategoryId",
                                    DisplayInputId = "CategoryDisplay",
                                    SearchUrl = "/lookup/categories",
                                    SelectedId = Model.CategoryId,
                                    DisplayValue = Model.CategoryDisplayName,
                                    Placeholder = "Search category...",
                                    HelpText = "Start typing to search categories."
                                })
                            </div>

                            <div class="col-md-6">
                                @await Html.PartialAsync("_AutocompleteDropdown", new AutocompleteDropdownModel
                                {
                                    Label = "Supplier",
                                    HiddenInputName = "SupplierId",
                                    HiddenInputId = "SupplierId",
                                    DisplayInputId = "SupplierDisplay",
                                    SearchUrl = "/lookup/suppliers",
                                    SelectedId = Model.SupplierId,
                                    DisplayValue = Model.SupplierDisplayName,
                                    Placeholder = "Search supplier...",
                                    HelpText = "Start typing to search suppliers."
                                })
                            </div>
                        </div>

                        @await Html.PartialAsync("_DateTimeInput", new DateTimeInputModel
                        {
                            Label = "Creation Date",
                            InputName = "CreatedAt",
                            InputId = "CreatedAt",
                            Value = Model.CreatedAt,
                            Placeholder = "Enter creation date",
                            HelpText = "Use your browser language format.",
                            IncludeTime = false,
                            IsRequired = true
                        })

                        <div class="mb-4">
                            <div class="form-check">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" id="IsActive" />
                                <label asp-for="IsActive" class="form-check-label fw-semibold">
                                    Product is Active
                                </label>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-info btn-lg text-white">
                                <i class="bi bi-check-circle"></i> Save Changes
                            </button>
                            <a href="@Url.RouteUrl("ProductCatalogDetails", new { id = Model.Id })" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm border-0 mt-4">
                <div class="card-header bg-light py-3">
                    <h5 class="mb-0">Product attachments</h5>
                </div>
                <div class="card-body p-4">
                    <form id="productAttachmentUploadForm" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label for="productAttachmentFiles" class="form-label fw-semibold">Upload files</label>
                            <input id="productAttachmentFiles" name="files" type="file" class="form-control" multiple />
                            <div class="form-text">Allowed: PDF, images, TXT, Word and Excel files. Maximum size: 10 MB per file.</div>
                        </div>
                        <button type="submit" class="btn btn-primary">Upload</button>
                        <span id="productAttachmentMessage" class="ms-3"></span>
                    </form>

                    <hr />

                    <div id="productAttachmentsContainer">
                        <div class="text-muted">Loading attachments...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const productId = @Model.Id;
            const listUrl = `/products/${productId}/attachments`;
            const uploadUrl = `/products/${productId}/attachments/upload`;
            const form = document.getElementById('productAttachmentUploadForm');
            const filesInput = document.getElementById('productAttachmentFiles');
            const container = document.getElementById('productAttachmentsContainer');
            const message = document.getElementById('productAttachmentMessage');

            async function loadAttachments() {
                const response = await fetch(listUrl, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                container.innerHTML = await response.text();
            }

            form.addEventListener('submit', async function (event) {
                event.preventDefault();
                message.textContent = '';
                message.className = 'ms-3';

                if (!filesInput.files.length) {
                    message.textContent = 'Choose at least one file.';
                    message.classList.add('text-danger');
                    return;
                }

                const formData = new FormData(form);

                const response = await fetch(uploadUrl, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (!response.ok) {
                    const contentType = response.headers.get('content-type') || '';
                    if (contentType.includes('application/json')) {
                        const data = await response.json();
                        message.textContent = data.message || 'Upload failed.';
                    } else {
                        message.textContent = 'Upload failed.';
                    }
                    message.classList.add('text-danger');
                    return;
                }

                container.innerHTML = await response.text();
                filesInput.value = '';
                message.textContent = 'Upload completed.';
                message.classList.add('text-success');
            });

            container.addEventListener('click', async function (event) {
                const button = event.target.closest('.js-delete-attachment');
                if (!button) {
                    return;
                }

                if (!confirm('Delete this attachment?')) {
                    return;
                }

                const attachmentId = button.dataset.attachmentId;
                const token = form.querySelector('input[name="__RequestVerificationToken"]').value;
                const formData = new FormData();
                formData.append('__RequestVerificationToken', token);

                const response = await fetch(`/products/${productId}/attachments/${attachmentId}/delete`, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (!response.ok) {
                    alert('Delete failed. Only Admin can delete attachments.');
                    return;
                }

                container.innerHTML = await response.text();
            });

            loadAttachments();
        });
    </script>
}
