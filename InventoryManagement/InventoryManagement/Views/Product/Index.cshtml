@using System
@using System.Linq
@model IEnumerable<InventoryManagement.Domain.Models.Product>

@{
    var products = Model?.ToList() ?? new List<InventoryManagement.Domain.Models.Product>();
    var total = products.Count;
    var activeCount = products.Count(p => p.IsActive);
    var minStockSet = products.Count(p => p.MinimumStock > 0);
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0 mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Products</li>
        </ol>
    </nav>

    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">Products</h1>
            <p class="text-muted mb-0">Overview of catalog items — pricing, supplier, category and stock thresholds.</p>
        </div>
        <div class="text-sm-end mt-3 mt-sm-0">
            <div class="mb-2">
                <a href="/catalog/create" class="btn btn-primary btn-sm" asp-authorize-role="Admin">
                    <i class="bi bi-plus-circle"></i> Create Product
                </a>
            </div>
            <small class="text-muted">Total products</small>
            <div class="h4 mb-0 fw-semibold">@total</div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <small class="text-muted">Active Products</small>
                            <div class="h5 mb-0">@activeCount</div>
                        </div>
                        <div>
                            <span class="badge bg-success fs-6">Active</span>
                        </div>
                    </div>
                    <div class="mt-2 text-muted small">Products currently marked as available</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <small class="text-muted">With Minimum Stock</small>
                            <div class="h5 mb-0">@minStockSet</div>
                        </div>
                        <div>
                            <span class="badge bg-info fs-6">Threshold</span>
                        </div>
                    </div>
                    <div class="mt-2 text-muted small">Products that have minimum stock configured</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-start border-3 border-primary">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <small class="text-muted">Catalog Health</small>
                            <div class="h5 mb-0">
                                @if (total == 0)
                                {
                                    <span class="text-warning">No items</span>
                                }
                                else
                                {
                                    <span>@((int)(100.0 * activeCount / Math.Max(1, total)))% active</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="mt-2 text-muted small">Quick gauge of active product coverage</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header d-flex align-items-center justify-content-between">
            <div>
                <h2 class="h6 mb-0">Product List</h2>
                <small class="text-muted">Read-only view — use Details to inspect an item.</small>
            </div>
            <div class="text-muted small">Records: @total</div>
        </div>

        <!-- Search UI -->
        <div class="card-body border-bottom pb-3">
            <div class="row g-2 align-items-center">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" id="productSearchInput" class="form-control border-start-0" placeholder="Search by product name, description, category, or supplier..." />
                    </div>
                </div>
                <div class="col-md-4 text-end">
                    <button type="button" id="clearProductSearch" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-x-circle"></i> Clear
                    </button>
                    <span id="productSearchLoading" class="ms-2" style="display: none;">
                        <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
                        <small class="text-muted ms-1">Searching...</small>
                    </span>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Name</th>
                        <th>Price</th>
                        <th>Type</th>
                        <th>Category</th>
                        <th>Supplier</th>
                        <th class="text-end">Min Stock</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="productTableBody">
                    @await Html.PartialAsync("_ProductTableRows", products)
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            let searchTimeout;

            // Handle product search input
            $('#productSearchInput').on('input', function() {
                clearTimeout(searchTimeout);
                const term = $(this).val().trim();

                // Show loading indicator
                $('#productSearchLoading').show();

                // Debounce search requests (300ms)
                searchTimeout = setTimeout(function() {
                    $.ajax({
                        url: '/catalog/search',
                        data: { term: term },
                        method: 'GET',
                        timeout: 5000,
                        success: function(html) {
                            // Fade out and replace content
                            $('#productTableBody').fadeOut(150, function() {
                                $(this).html(html).fadeIn(150);
                            });
                        },
                        error: function() {
                            $('#productTableBody').html('<tr><td colspan="8" class="text-center text-danger py-4">Error loading results. Please try again.</td></tr>');
                        },
                        complete: function() {
                            // Hide loading indicator
                            $('#productSearchLoading').hide();
                        }
                    });
                }, 300);
            });

            // Handle clear button
            $('#clearProductSearch').on('click', function() {
                $('#productSearchInput').val('').focus();
                clearTimeout(searchTimeout);
                $('#productSearchLoading').show();

                // Reload all products
                $.ajax({
                    url: '/catalog/search',
                    data: { term: '' },
                    method: 'GET',
                    timeout: 5000,
                    success: function(html) {
                        $('#productTableBody').fadeOut(150, function() {
                            $(this).html(html).fadeIn(150);
                        });
                    },
                    complete: function() {
                        $('#productSearchLoading').hide();
                    }
                });
            });
        });
    </script>
}
