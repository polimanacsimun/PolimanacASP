@using System
@using System.Linq
@model IEnumerable<InventoryManagement.Domain.Models.Product>

@{
    var products = Model?.ToList() ?? new List<InventoryManagement.Domain.Models.Product>();
    var total = products.Count;
    var activeCount = products.Count(p => p.IsActive);
    var minStockSet = products.Count(p => p.MinimumStock > 0);
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0 mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Products</li>
        </ol>
    </nav>

    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">Products</h1>
            <p class="text-muted mb-0">Overview of catalog items — pricing, supplier, category and stock thresholds.</p>
        </div>
        <div class="text-sm-end mt-3 mt-sm-0">
            <small class="text-muted">Total products</small>
            <div class="h4 mb-0 fw-semibold">@total</div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <small class="text-muted">Active Products</small>
                            <div class="h5 mb-0">@activeCount</div>
                        </div>
                        <div>
                            <span class="badge bg-success fs-6">Active</span>
                        </div>
                    </div>
                    <div class="mt-2 text-muted small">Products currently marked as available</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <small class="text-muted">With Minimum Stock</small>
                            <div class="h5 mb-0">@minStockSet</div>
                        </div>
                        <div>
                            <span class="badge bg-info fs-6">Threshold</span>
                        </div>
                    </div>
                    <div class="mt-2 text-muted small">Products that have minimum stock configured</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-start border-3 border-primary">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <small class="text-muted">Catalog Health</small>
                            <div class="h5 mb-0">
                                @if (total == 0)
                                {
                                    <span class="text-warning">No items</span>
                                }
                                else
                                {
                                    <span>@((int)(100.0 * activeCount / Math.Max(1, total)))% active</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="mt-2 text-muted small">Quick gauge of active product coverage</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header d-flex align-items-center justify-content-between">
            <div>
                <h2 class="h6 mb-0">Product List</h2>
                <small class="text-muted">Read-only view — use Details to inspect an item.</small>
            </div>
            <div class="text-muted small">Records: @total</div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Name</th>
                        <th>Price</th>
                        <th>Type</th>
                        <th>Category</th>
                        <th>Supplier</th>
                        <th class="text-end">Min Stock</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!products.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">No products found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in products)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-semibold">@item.Name</div>
                                    <div class="text-muted small">@item.Category?.Name ?? "—"</div>
                                </td>
                                <td>@(item.Price.ToString("C"))</td>
                                <td><span class="badge bg-secondary">@item.Type</span></td>
                                <td>@(item.Category?.Name ?? "-")</td>
                                <td>@(item.Supplier?.Name ?? "-")</td>
                                <td class="text-end">@item.MinimumStock</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        Details
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
