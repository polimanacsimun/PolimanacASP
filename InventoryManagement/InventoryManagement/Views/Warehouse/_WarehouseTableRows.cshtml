@using System
@using System.Linq
@model IEnumerable<InventoryManagement.Domain.Models.Warehouse>

@{
    var warehouses = Model?.ToList() ?? new List<InventoryManagement.Domain.Models.Warehouse>();
}

@if (!warehouses.Any())
{
    <tr>
        <td colspan="7" class="text-center text-muted py-4">No warehouses found.</td>
    </tr>
}
else
{
    @foreach (var item in warehouses)
    {
        <tr>
            <td class="ps-4">
                <div class="fw-semibold">@item.Name</div>
                <div class="text-muted small">@(string.IsNullOrEmpty(item.Address) ? "—" : item.Address)</div>
            </td>
            <td>@item.Capacity</td>
            <td>@(string.IsNullOrEmpty(item.Phone) ? "—" : item.Phone)</td>
            <td>@(string.IsNullOrEmpty(item.Email) ? "—" : item.Email)</td>
            <td>@(string.IsNullOrEmpty(item.Manager) ? "—" : item.Manager)</td>
            <td>
                @if (item.IsActive)
                {
                    <span class="badge bg-success">Active</span>
                }
                else
                {
                    <span class="badge bg-secondary">Inactive</span>
                }
            </td>
            <td class="text-end pe-4">
                <div class="btn-group btn-group-sm" role="group">
                    <a href="/storage/@item.Id" class="btn btn-outline-primary" title="View Details">
                        Details
                    </a>
                    <a href="/storage/@item.Id/edit" class="btn btn-outline-info" title="Edit Warehouse">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a href="/storage/@item.Id/delete" class="btn btn-outline-danger" title="Delete Warehouse">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </td>
        </tr>
    }
}
