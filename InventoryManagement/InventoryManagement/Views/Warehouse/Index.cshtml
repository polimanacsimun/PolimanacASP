@using System
@using System.Linq
@using InventoryManagement.Domain.Enums
@model IEnumerable<InventoryManagement.Domain.Models.Warehouse>

@{
    ViewData["Title"] = "Warehouses";
    var warehouses = Model?.ToList() ?? new List<InventoryManagement.Domain.Models.Warehouse>();
    var totalCount = warehouses.Count;
    var totalCapacity = warehouses.Sum(w => (long?)w?.Capacity) ?? 0L;
    DateTime? earliestOpening = warehouses.Any() ? warehouses.Min(w => (DateTime?)w?.OpeningDate) : null;
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent ps-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Warehouses</li>
        </ol>
    </nav>

    <header class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">Warehouses</h1>
            <p class="text-muted mb-0">Overview of the warehouse network, capacity and operational status.</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/storage/create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle"></i> Create Warehouse
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
        </div>
    </header>

    <!-- Metric Cards -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <h6 class="text-uppercase text-muted mb-1">Total Warehouses</h6>
                            <h3 class="mb-0">@totalCount</h3>
                        </div>
                        <div class="ms-3">
                            <span class="fs-3 text-secondary">🏬</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-uppercase text-muted mb-1">Total Capacity</h6>
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h3 class="mb-0">@string.Format("{0:N0}", totalCapacity)</h3>
                            <small class="text-muted">Units (sum of Capacity)</small>
                        </div>
                        <div class="ms-3 text-secondary fs-3">📦</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-12 col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-uppercase text-muted mb-1">Earliest Established</h6>
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h5 class="mb-0">@((earliestOpening.HasValue) ? earliestOpening.Value.ToString("MMM d, yyyy") : "—")</h5>
                            <small class="text-muted">Oldest warehouse in the network</small>
                        </div>
                        <div class="ms-3 text-secondary fs-3">📅</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content: Table of Warehouses -->
    @if (!warehouses.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <h5 class="mb-2">No warehouses found</h5>
                <p class="text-muted mb-3">There are currently no storage locations registered in the system.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Return to Dashboard</a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header bg-white border-bottom">
                <div class="row g-2 align-items-center">
                    <div class="col-md-8">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-0">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" id="warehouseSearchInput" class="form-control border-start-0" placeholder="Search by name, address, phone, email, manager or type..." />
                        </div>
                    </div>
                    <div class="col-md-4 text-end">
                        <button type="button" id="clearWarehouseSearch" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-x-circle"></i> Clear
                        </button>
                        <span id="warehouseSearchLoading" class="ms-2" style="display: none;">
                            <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
                            <small class="text-muted ms-1">Searching...</small>
                        </span>
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Name</th>
                                <th scope="col">Capacity</th>
                                <th scope="col">Phone</th>
                                <th scope="col">Email</th>
                                <th scope="col">Manager</th>
                                <th scope="col">Status</th>
                                <th scope="col" class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="warehouseTableBody">
                            @await Html.PartialAsync("_WarehouseTableRows", warehouses)
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer text-muted small d-flex justify-content-between">
                <div>Showing <strong>@totalCount</strong> warehouses</div>
                <div>Updated: @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</div>
            </div>
        </div>
    }

    <footer class="mt-4 text-muted small d-flex justify-content-between">
        <div>Inventory Management • Warehouses</div>
        <div><a asp-controller="Home" asp-action="Index">Back to Home</a></div>
    </footer>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            let searchTimeout;

            // Handle warehouse search input
            $('#warehouseSearchInput').on('input', function() {
                clearTimeout(searchTimeout);
                const term = $(this).val().trim();

                // Show loading indicator
                $('#warehouseSearchLoading').show();

                // Debounce search requests (300ms)
                searchTimeout = setTimeout(function() {
                    $.ajax({
                        url: '/storage/search',
                        data: { term: term },
                        method: 'GET',
                        timeout: 5000,
                        success: function(html) {
                            // Fade out and replace content
                            $('#warehouseTableBody').fadeOut(150, function() {
                                $(this).html(html).fadeIn(150);
                            });
                        },
                        error: function() {
                            $('#warehouseTableBody').html('<tr><td colspan="7" class="text-center text-danger py-4">Error loading results. Please try again.</td></tr>');
                        },
                        complete: function() {
                            // Hide loading indicator
                            $('#warehouseSearchLoading').hide();
                        }
                    });
                }, 300);
            });

            // Handle clear button
            $('#clearWarehouseSearch').on('click', function() {
                $('#warehouseSearchInput').val('').focus();
                clearTimeout(searchTimeout);
                $('#warehouseSearchLoading').show();

                // Reload all warehouses
                $.ajax({
                    url: '/storage/search',
                    data: { term: '' },
                    method: 'GET',
                    timeout: 5000,
                    success: function(html) {
                        $('#warehouseTableBody').fadeOut(150, function() {
                            $(this).html(html).fadeIn(150);
                        });
                    },
                    complete: function() {
                        $('#warehouseSearchLoading').hide();
                    }
                });
            });
        });
    </script>
}
