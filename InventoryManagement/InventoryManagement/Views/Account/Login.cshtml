@model InventoryManagement.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="auth-stage row justify-content-center align-items-center py-4 py-lg-5">
    <div class="col-md-8 col-lg-6 col-xl-5 col-xxl-4">
        <div class="card login-card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="login-card-hero p-4 p-lg-5 text-white">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="brand-mark login-brand-mark" aria-hidden="true">
                        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="3" y="4" width="18" height="4" rx="1.2" fill="white" fill-opacity=".95" />
                            <rect x="3" y="10" width="18" height="4" rx="1.2" fill="white" fill-opacity=".82" />
                            <rect x="3" y="16" width="11" height="4" rx="1.2" fill="white" fill-opacity=".68" />
                        </svg>
                    </div>
                    <div>
                        <h1 class="display-6 fw-bold mb-1">Welcome back</h1>
                        <div class="text-white-50">Sign in to open the inventory dashboard.</div>
                    </div>
                </div>
            </div>

            <div class="card-body p-4 p-lg-5">
                <form asp-action="Login" method="post" asp-route-returnUrl="@returnUrl">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control form-control-lg" autocomplete="username" placeholder="admin@inventory.local" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <input asp-for="Password" class="form-control form-control-lg" autocomplete="current-password" placeholder="Enter password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">Login</button>
                    <div class="text-center small text-muted">
                        No account yet?
                        <a asp-controller="Account" asp-action="Register">Create one</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
