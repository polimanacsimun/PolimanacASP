@using System
@using System.Globalization
@model InventoryManagement.Domain.Models.InventoryItem

@{
    ViewData["Title"] = "Inventory Item Details";
    var culture = CultureInfo.CurrentCulture;
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a href="/inventory">Inventory Records</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    <!-- Header with Navigation Buttons -->
    <div class="d-flex align-items-start justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">@Model?.Product?.Name</h1>
            <p class="text-muted mb-0">Inventory record in @Model?.Warehouse?.Name</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/inventory/@Model?.Id/edit" class="btn btn-outline-info btn-sm">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a href="/inventory/@Model?.Id/delete" class="btn btn-outline-danger btn-sm">
                <i class="bi bi-trash"></i> Delete
            </a>
            <a href="/inventory" class="btn btn-outline-secondary btn-sm">
                &larr; Back
            </a>
        </div>
    </div>

    <div class="row g-3">
        <!-- Left Column: Inventory Information -->
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-light border-bottom">
                    <strong>Inventory Details</strong>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Product</dt>
                        <dd class="col-sm-8 fw-semibold">@Model?.Product?.Name</dd>

                        <dt class="col-sm-4 text-muted">Warehouse</dt>
                        <dd class="col-sm-8 fw-semibold">@Model?.Warehouse?.Name</dd>

                        <dt class="col-sm-4 text-muted">Current Stock</dt>
                        <dd class="col-sm-8">@Model?.QuantityInStock</dd>

                        <dt class="col-sm-4 text-muted">Minimum Level</dt>
                        <dd class="col-sm-8">@Model?.MinimumQuantity</dd>

                        <dt class="col-sm-4 text-muted">Maximum Level</dt>
                        <dd class="col-sm-8">@Model?.MaximumQuantity</dd>

                        <dt class="col-sm-4 text-muted">Shelf Location</dt>
                        <dd class="col-sm-8">@(!string.IsNullOrWhiteSpace(Model?.ShelfLocation) ? Model.ShelfLocation : "—")</dd>

                        <dt class="col-sm-4 text-muted">Last Checked</dt>
                        <dd class="col-sm-8">@Model?.LastCheckedAt.ToString("dd MMM yyyy HH:mm", culture)</dd>
                    </dl>
                </div>
                <div class="card-footer bg-light text-muted small">
                    Item ID: <span class="text-body">@Model?.Id</span> | Updated: @DateTime.Now.ToString("dd MMM yyyy HH:mm", culture)
                </div>
            </div>
        </div>

        <!-- Right Column: Summary Metrics -->
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light border-bottom">
                    <strong>Stock Summary</strong>
                </div>
                <div class="card-body">
                    <div class="row g-3 text-center">
                        <div class="col-6">
                            <div class="p-3 border rounded">
                                <div class="h6 mb-1">Current</div>
                                <div class="fs-4 fw-bold">@Model?.QuantityInStock</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 border rounded">
                                <div class="h6 mb-1">Min/Max</div>
                                <div class="fs-6 fw-semibold">@Model?.MinimumQuantity / @Model?.MaximumQuantity</div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="p-3 border rounded">
                                <div class="h6 mb-1">Stock Level</div>
                                @{
                                    string stockStatus = "Normal";
                                    string badgeClass = "bg-success";
                                    if (Model != null && Model.QuantityInStock < Model.MinimumQuantity)
                                    {
                                        stockStatus = "Below Minimum";
                                        badgeClass = "bg-danger";
                                    }
                                    else if (Model != null && Model.QuantityInStock > Model.MaximumQuantity)
                                    {
                                        stockStatus = "Above Maximum";
                                        badgeClass = "bg-warning text-dark";
                                    }
                                }
                                <span class="badge @badgeClass">@stockStatus</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light text-muted small">
                    <div>Last checked: @Model?.LastCheckedAt.ToString("d", culture)</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer Navigation -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-muted small">
            Created: @Model?.LastCheckedAt.ToString("f", culture)
        </div>
        <div class="d-flex gap-2">
            <a href="/inventory/@Model?.Id/edit" class="btn btn-sm btn-outline-info">
                <i class="bi bi-pencil"></i> Edit Record
            </a>
            <a href="/inventory" class="btn btn-sm btn-outline-secondary">
                Back to Inventory
            </a>
        </div>
    </div>
</div>
