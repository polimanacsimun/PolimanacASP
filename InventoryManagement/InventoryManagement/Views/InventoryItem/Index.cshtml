@using System
@using System.Linq
@model IEnumerable<InventoryManagement.Domain.Models.InventoryItem>

@{
    ViewData["Title"] = "Inventory Records";
    var items = (Model ?? Enumerable.Empty<InventoryManagement.Domain.Models.InventoryItem>()).ToList();
}

<div class="container my-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0 m-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Inventory Records</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex align-items-start justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-1">Inventory Records</h1>
            <p class="text-muted small mb-0">Manage product inventory across warehouses — track stock levels, reorder points, and storage locations.</p>
        </div>
        <div class="text-end d-flex gap-2">
            <a href="/inventory/create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle"></i> Create Inventory Record
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
        </div>
    </div>

    <!-- Inventory Table -->
    @if (!items.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <h4 class="mb-2">No inventory records yet</h4>
                <p class="text-muted mb-3">There are currently no inventory records in the system. Create your first record to get started.</p>
                <a href="/inventory/create" class="btn btn-primary">Create Inventory Record</a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header bg-white border-bottom">
                <div class="row g-2 align-items-center">
                    <div class="col-md-8">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-0">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" id="inventorySearchInput" class="form-control border-start-0" placeholder="Search by product, warehouse, or shelf location..." />
                        </div>
                    </div>
                    <div class="col-md-4 text-end">
                        <button type="button" id="clearInventorySearch" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-x-circle"></i> Clear
                        </button>
                        <span id="inventorySearchLoading" class="ms-2" style="display: none;">
                            <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
                            <small class="text-muted ms-1">Searching...</small>
                        </span>
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Product</th>
                                <th scope="col">Warehouse</th>
                                <th scope="col" class="text-center">Quantity</th>
                                <th scope="col" class="text-center">Minimum</th>
                                <th scope="col" class="text-center">Maximum</th>
                                <th scope="col">Shelf</th>
                                <th scope="col">Last Checked</th>
                                <th scope="col" class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="inventoryTableBody">
                            @await Html.PartialAsync("_InventoryItemTableRows", items)
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Footer -->
    <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="text-muted small">Total records: @items.Count</div>
        <div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-link">Back to Dashboard</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            let searchTimeout;

            // Handle inventory search input
            $('#inventorySearchInput').on('input', function() {
                clearTimeout(searchTimeout);
                const term = $(this).val().trim();

                // Show loading indicator
                $('#inventorySearchLoading').show();

                // Debounce search requests (300ms)
                searchTimeout = setTimeout(function() {
                    $.ajax({
                        url: '/inventory/search',
                        data: { term: term },
                        method: 'GET',
                        timeout: 5000,
                        success: function(html) {
                            // Fade out and replace content
                            $('#inventoryTableBody').fadeOut(150, function() {
                                $(this).html(html).fadeIn(150);
                            });
                        },
                        error: function() {
                            $('#inventoryTableBody').html('<tr><td colspan="8" class="text-center text-danger py-4">Error loading results. Please try again.</td></tr>');
                        },
                        complete: function() {
                            // Hide loading indicator
                            $('#inventorySearchLoading').hide();
                        }
                    });
                }, 300);
            });

            // Handle clear button
            $('#clearInventorySearch').on('click', function() {
                $('#inventorySearchInput').val('').focus();
                clearTimeout(searchTimeout);
                $('#inventorySearchLoading').show();

                // Reload all records
                $.ajax({
                    url: '/inventory/search',
                    data: { term: '' },
                    method: 'GET',
                    timeout: 5000,
                    success: function(html) {
                        $('#inventoryTableBody').fadeOut(150, function() {
                            $(this).html(html).fadeIn(150);
                        });
                    },
                    complete: function() {
                        $('#inventorySearchLoading').hide();
                    }
                });
            });
        });
    </script>
}
