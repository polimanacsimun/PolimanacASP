@using System
@using System.Linq
@model IEnumerable<InventoryManagement.Domain.Models.Order>

@{
    var orders = Model?.ToList() ?? new List<InventoryManagement.Domain.Models.Order>();
}

@if (!orders.Any())
{
    <tr>
        <td colspan="7" class="text-center text-muted py-4">No orders found.</td>
    </tr>
}
else
{
    @foreach (var item in orders)
    {
        <tr>
            <td class="ps-4">
                <div class="fw-semibold">@item.OrderNumber</div>
            </td>
            <td>
                <div class="fw-semibold">@(item.User != null ? $"{item.User.FirstName} {item.User.LastName}" : "—")</div>
                <div class="text-muted small">@(item.User?.Email ?? "—")</div>
            </td>
            <td>@item.OrderDate.ToString("dd MMM yyyy")</td>
            <td class="text-end">@item.TotalPrice.ToString("C")</td>
            <td>@item.Status</td>
            <td>
                @if (item.OrderItems != null && item.OrderItems.Any())
                {
                    <span class="badge bg-info">@item.OrderItems.Count items</span>
                }
                else
                {
                    <span class="badge bg-secondary">0 items</span>
                }
            </td>
            <td class="text-end pe-4">
                <div class="btn-group btn-group-sm" role="group">
                    <a href="/orders/@item.Id/summary" class="btn btn-outline-primary" title="View Details">
                        Details
                    </a>
                    <a href="/orders/@item.Id/edit" class="btn btn-outline-info" title="Edit Order" asp-authorize-role="Admin">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a href="/orders/@item.Id/delete" class="btn btn-outline-danger" title="Delete Order" asp-authorize-role="Admin">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </td>
        </tr>
    }
}
