@using System
@using System.Linq
@using System.Globalization
@using InventoryManagement.Domain.Models
@using InventoryManagement.Domain.Enums
@model InventoryManagement.Domain.Models.Order

@{
    ViewData["Title"] = "Order Details";
    var culture = CultureInfo.CurrentCulture;
    var customerName = Model?.User != null ? $"{Model.User.FirstName} {Model.User.LastName}" : "Unknown";
    var items = Model?.OrderItems ?? Enumerable.Empty<OrderItem>();
    int itemCount = items.Count();
    decimal totalItems = items.Sum(oi => (decimal?)(oi?.Quantity) ?? 0m);

    Func<OrderStatus, string> statusBadgeClass = s => s switch
    {
        OrderStatus.Pending => "badge bg-warning text-dark",
        OrderStatus.Processing => "badge bg-info text-white",
        OrderStatus.Delivered => "badge bg-success",
        OrderStatus.Cancelled => "badge bg-danger",
        _ => "badge bg-secondary"
    };
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a href="/orders/history">Orders</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model?.OrderNumber</li>
        </ol>
    </nav>

    <!-- Header with Navigation Buttons -->
    <div class="d-flex align-items-start justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">@Model?.OrderNumber</h1>
            <p class="text-muted mb-0">Order details and fulfillment status for @customerName</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/orders/@Model?.Id/edit" class="btn btn-outline-info btn-sm" asp-authorize-role="Admin">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a href="/orders/@Model?.Id/delete" class="btn btn-outline-danger btn-sm" asp-authorize-role="Admin">
                <i class="bi bi-trash"></i> Delete
            </a>
            <a href="/orders/history" class="btn btn-outline-secondary btn-sm">
                &larr; Back to Orders
            </a>
        </div>
    </div>

    <div class="row g-3">
        <!-- Left Column: Order Information -->
        <div class="col-12 col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-light border-bottom">
                    <strong>Order Information</strong>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Order Number</dt>
                        <dd class="col-sm-8 fw-semibold">@Model?.OrderNumber</dd>

                        <dt class="col-sm-4 text-muted">Customer</dt>
                        <dd class="col-sm-8">
                            @if (Model?.User != null)
                            {
                                <div>@Model.User.FirstName @Model.User.LastName</div>
                                <small class="text-muted">@Model.User.Email</small>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </dd>

                        <dt class="col-sm-4 text-muted">Order Date</dt>
                        <dd class="col-sm-8">@Model?.OrderDate.ToString("dd MMM yyyy", culture)</dd>

                        <dt class="col-sm-4 text-muted">Total Price</dt>
                        <dd class="col-sm-8 fw-semibold">@Model?.TotalPrice.ToString("C", culture)</dd>

                        <dt class="col-sm-4 text-muted">Status</dt>
                        <dd class="col-sm-8">
                            @if (Model != null)
                            {
                                <span class="@statusBadgeClass(Model.Status)">@Model.Status</span>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </dd>

                        <dt class="col-sm-4 text-muted">Delivery Date</dt>
                        <dd class="col-sm-8">@(Model?.DeliveryDate.HasValue == true ? Model.DeliveryDate.Value.ToString("dd MMM yyyy", culture) : "Pending")</dd>

                        <dt class="col-sm-4 text-muted">Note</dt>
                        <dd class="col-sm-8">@(!string.IsNullOrWhiteSpace(Model?.Note) ? Model.Note : "—")</dd>
                    </dl>
                </div>
                <div class="card-footer bg-light text-muted small">
                    Order ID: <span class="text-body">@Model?.Id</span> | Updated: @DateTime.Now.ToString("dd MMM yyyy HH:mm", culture)
                </div>
            </div>
        </div>

        <!-- Right Column: Summary Metrics -->
        <div class="col-12 col-lg-5">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light border-bottom">
                    <strong>Order Summary</strong>
                </div>
                <div class="card-body">
                    <div class="row g-3 text-center">
                        <div class="col-6">
                            <div class="p-3 border rounded">
                                <div class="h6 mb-1">Total Items</div>
                                <div class="fs-4 fw-bold">@itemCount</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 border rounded">
                                <div class="h6 mb-1">Total Quantity</div>
                                <div class="fs-4 fw-bold">@totalItems</div>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="p-3 border rounded">
                                <div class="h6 mb-1">Order Amount</div>
                                <div class="fs-5 fw-semibold">@Model?.TotalPrice.ToString("C", culture)</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 border rounded">
                                <div class="h6 mb-1">Status</div>
                                <div class="fs-6">@(Model != null ? Model.Status.ToString() : "—")</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light text-muted small">
                    <div>Last updated: @DateTime.Now.ToString("g", culture)</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Order Items Full-width Section -->
    <div class="card shadow-sm mt-4">
        <div class="card-header bg-light border-bottom d-flex justify-content-between align-items-center">
            <div>
                <strong>Order Items</strong>
                <span class="text-muted small"> — products in this order</span>
            </div>
            <small class="text-muted">@(itemCount + " item(s)")</small>
        </div>
        <div class="card-body p-0">
            @if (!items.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 mb-2 d-block"></i>
                    <p>This order contains no items.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th class="text-center">Quantity</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in items)
                            {
                                decimal itemTotal = (item?.Quantity ?? 0) * (item?.UnitPrice ?? 0m);
                                <tr>
                                    <td class="fw-semibold">@(item?.Product?.Name ?? "—")</td>
                                    <td class="text-center">@item?.Quantity</td>
                                    <td class="text-end">@item?.UnitPrice.ToString("C", culture)</td>
                                    <td class="text-end fw-semibold">@itemTotal.ToString("C", culture)</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-semibold">Total:</td>
                                <td class="text-end fw-bold">@Model?.TotalPrice.ToString("C", culture)</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Footer Navigation -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-muted small">
            Order created: @Model?.OrderDate.ToString("f", culture)
        </div>
        <div class="d-flex gap-2">
            <a href="/orders/@Model?.Id/edit" class="btn btn-sm btn-outline-info" asp-authorize-role="Admin">
                <i class="bi bi-pencil"></i> Edit Order
            </a>
            <a href="/orders/history" class="btn btn-sm btn-outline-secondary">
                Back to Orders
            </a>
        </div>
    </div>
</div>
