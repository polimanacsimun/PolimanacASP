@using System
@using System.Linq
@using System.Globalization
@using InventoryManagement.Domain.Models
@using InventoryManagement.Domain.Enums
@model IEnumerable<InventoryManagement.Domain.Models.Order>

@{
    ViewData["Title"] = "Orders";
    var culture = CultureInfo.CurrentCulture;
    var orders = (Model ?? Enumerable.Empty<Order>()).OrderByDescending(o => o?.OrderDate ?? DateTime.MinValue).ToList();

    var totalOrders = orders.Count();
    var pendingCount = orders.Count(o => o?.Status == OrderStatus.Pending);
    var processingCount = orders.Count(o => o?.Status == OrderStatus.Processing);
    var deliveredCount = orders.Count(o => o?.Status == OrderStatus.Delivered);
    var cancelledCount = orders.Count(o => o?.Status == OrderStatus.Cancelled);
    var totalRevenue = orders.Sum(o => (decimal?)(o?.TotalPrice) ?? 0m);
}

<div class="container my-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0 m-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Orders</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex align-items-start justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-1">Orders</h1>
            <p class="text-muted small mb-0">Overview of order management and fulfillment — review statuses, revenue and recent activity.</p>
        </div>
        <div class="text-end">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
        </div>
    </div>

    <!-- Metrics -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted">Total Orders</small>
                    <div class="d-flex align-items-baseline justify-content-between">
                        <h3 class="mb-0">@totalOrders</h3>
                        <i class="bi bi-list-check fs-4 text-muted"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted">Pending</small>
                    <div class="d-flex align-items-baseline justify-content-between">
                        <h4 class="mb-0 text-danger">@pendingCount</h4>
                        <span class="badge bg-danger align-self-start">Pending</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted">Processing</small>
                    <div class="d-flex align-items-baseline justify-content-between">
                        <h4 class="mb-0 text-warning">@processingCount</h4>
                        <span class="badge bg-warning text-dark align-self-start">Processing</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted">Delivered</small>
                    <div class="d-flex align-items-baseline justify-content-between">
                        <h4 class="mb-0 text-success">@deliveredCount</h4>
                        <span class="badge bg-success align-self-start">Delivered</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6">
            <div class="card shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted">Total Revenue</small>
                        <div class="h4 mb-0">@totalRevenue.ToString("C", culture)</div>
                    </div>
                    <div class="text-end text-muted small">Updated: @DateTime.Now.ToString("g", culture)</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <small class="text-muted">Other Summary</small>
                    <div class="d-flex gap-3 mt-2">
                        <div>
                            <div class="fw-bold">@cancelledCount</div>
                            <div class="text-muted small">Cancelled</div>
                        </div>
                        <div>
                            <div class="fw-bold">@orders.Sum(o => (int?)(o?.OrderItems?.Count) ?? 0)</div>
                            <div class="text-muted small">Total Items</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Orders Table -->
    @if (!orders.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <h4 class="mb-2">No orders yet</h4>
                <p class="text-muted mb-3">There are currently no orders in the system. Orders will appear here as they are placed.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Go to Dashboard</a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Order #</th>
                                <th scope="col">Customer</th>
                                <th scope="col">Order Date</th>
                                <th scope="col">Items</th>
                                <th scope="col">Total</th>
                                <th scope="col">Status</th>
                                <th scope="col">Delivery</th>
                                <th scope="col">Note</th>
                                <th scope="col" class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in orders)
                            {
                                var userName = (order?.User != null) ? $"{order.User.FirstName} {order.User.LastName}" : "Unknown";
                                var itemsCount = order?.OrderItems?.Count ?? 0;
                                var deliveryText = order?.DeliveryDate.HasValue == true ? order.DeliveryDate.Value.ToString("d", culture) : "Pending";
                                string badgeClass = order?.Status switch
{
    OrderStatus.Delivered => "badge bg-success",
    OrderStatus.Processing => "badge bg-info text-white",
    OrderStatus.Pending => "badge bg-warning text-dark",
    OrderStatus.Cancelled => "badge bg-danger",
    _ => "badge bg-secondary"
};

                                <tr>
                                    <td class="fw-semibold">@Html.DisplayFor(m => order.OrderNumber)</td>
                                    <td>@userName</td>
                                    <td>@(order?.OrderDate.ToString("g", culture) ?? "-")</td>
                                    <td>@itemsCount</td>
                                    <td>@(order != null ? order.TotalPrice.ToString("C", culture) : "-")</td>
                                    <td><span class="@badgeClass">@order?.Status.ToString()</span></td>
                                    <td>@deliveryText</td>
                                    <td class="text-truncate" style="max-width:220px;">@(!string.IsNullOrWhiteSpace(order?.Note) ? order.Note : "—")</td>
                                    <td class="text-end">
                                        <a asp-controller="Order" asp-action="Details" asp-route-id="@order?.Id" class="btn btn-sm btn-outline-primary">Details</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Footer -->
    <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="text-muted small">Updated: @DateTime.Now.ToString("f", culture)</div>
        <div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-link">Back to Dashboard</a>
        </div>
    </div>
</div>
